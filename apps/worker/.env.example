# Mesma base de dados que apps/web (Prisma).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/subtitle_studio?schema=public"

# OpenAI (transcrição Whisper) — mesmo uso que no web.
OPENAI_API_KEY=
# Segredo para decifrar chave OpenAI guardada por utilizador (deve coincidir com apps/api).
OPENAI_KEY_ENCRYPTION_SECRET=

# Diretório de mídia (opcional). Por defeito: ../web/public/uploads/media com cwd em apps/worker.
# MEDIA_STORAGE_DIR=

# Intervalo entre polls quando não há jobs PENDING (ms). Mínimo recomendado: 200.
WORKER_POLL_MS=2000

# Opcional (alinhado ao web)
# MAX_TRANSCRIPTION_ATTEMPTS=3
# FFMPEG_BIN=

# --- Email de convite (Resend) ---
# Crie uma chave em https://resend.com — envio assíncrono após POST /api/admin/invites.
# Sem chave, o worker marca o envio como FAILED com mensagem explícita (convite na mesma criado).
RESEND_API_KEY=
# Remetente autorizado na conta Resend (domínio verificado ou sandbox onboarding@resend.dev).
EMAIL_FROM=SubtitleBot <onboarding@resend.dev>
