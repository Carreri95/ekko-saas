API_PORT=4000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/subtitle_studio?schema=public"

# --- PR 5.1 — upload local de mídia (POST /api/projects/:id/media) ---
# Por defeito grava em ../web/public/uploads/media (cwd = apps/api). Override:
# MEDIA_STORAGE_DIR=C:/caminho/absoluto/para/apps/web/public/uploads/media
# MAX_FILE_SIZE_MB=500

# --- Storage S3-compatible (MinIO em dev) — PR 4.2 ---
# Sem S3_ENDPOINT, a API ignora storage (GET /health/storage => disabled).
# Com as variáveis abaixo (descomentadas), GET /health/storage valida ListBuckets.
# Rotas de negócio (/media, etc.) ainda NÃO usam isto.
# Após: docker compose -f infra/docker/docker-compose.dev.yml up -d
# S3_ENDPOINT=http://127.0.0.1:9000
# S3_REGION=us-east-1
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET_MEDIA=subtitlebot-media
# S3_BUCKET_TEMP=subtitlebot-temp
# S3_FORCE_PATH_STYLE=true
