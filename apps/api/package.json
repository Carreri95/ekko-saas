{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "db:generate": "prisma generate --config prisma.config.ts",
    "db:validate": "prisma validate --config prisma.config.ts",
    "db:migrate": "prisma migrate dev --config prisma.config.ts",
    "db:deploy": "prisma migrate deploy --config prisma.config.ts",
    "db:studio": "prisma studio --config prisma.config.ts --port 5556",
    "storage:bootstrap": "tsx src/scripts/bootstrap-storage-buckets.ts",
    "media:reconcile": "tsx src/scripts/reconcile-media-assets.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1015.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/multipart": "^9.4.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@subtitlebot/shared": "*",
    "adm-zip": "^0.5.16",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "fastify": "^5.6.1",
    "music-metadata": "^11.12.3",
    "subtitlebot": "file:../..",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^24.5.2",
    "prisma": "^7.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2"
  }
}
