generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

/// Cliente gerado para `apps/web` (seed, tooling). Fonte de verdade única: este schema.
generator client_web {
  provider = "prisma-client"
  output   = "../../web/app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

model User {
  id           String    @id @default(cuid())
  name         String?
  displayName  String?
  avatarUrl    String?
  email        String?   @unique
  passwordHash String?
  /// Chave OpenAI/Whisper cifrada (AES-GCM). Nunca retornar ao frontend.
  openAiWhisperKeyEncrypted String?
  /// Máscara segura para UI (ex.: sk-...ABCD), sem expor segredo completo.
  openAiWhisperKeyMask      String?
  role         Role      @default(USER)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  projects     Project[]
  batchJobs    BatchJob[]
  sessions     Session[]
  invitesSent  Invite[] @relation("InviteInvitedBy")
}

/// Convite por email; token apenas como hash. Nesta fase o produto só prevê convites com `role` USER (regra de negócio nas rotas futuras).
model Invite {
  id              String    @id @default(cuid())
  email           String
  role            Role      @default(USER)
  tokenHash       String
  invitedByUserId String
  invitedBy       User      @relation("InviteInvitedBy", fields: [invitedByUserId], references: [id], onDelete: Restrict)
  expiresAt       DateTime
  acceptedAt      DateTime?
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  emailDispatch   InviteEmailDispatch?

  @@index([email])
  @@index([invitedByUserId])
}

/// Fila mínima de envio de email (outbox): URL com token só até envio bem-sucedido; depois `inviteUrl` fica null.
enum InviteEmailDispatchStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

model InviteEmailDispatch {
  id           String                    @id @default(cuid())
  inviteId     String                    @unique
  invite       Invite                    @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  toEmail      String
  /// Link completo com `?token=`; removido após envio bem-sucedido (não persistir token além do necessário).
  inviteUrl    String?
  status       InviteEmailDispatchStatus @default(PENDING)
  lastError    String?
  attemptCount Int                       @default(0)
  sentAt       DateTime?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt

  @@index([status, createdAt])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([tokenHash])
  @@index([userId])
}

model Project {
  id                String             @id @default(cuid())
  name              String
  description       String?
  status            ProjectStatus      @default(DRAFT)
  storageKey        String?
  mediaKind         MediaKind?
  durationMs        Int?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  userId            String
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  subtitleFiles     SubtitleFile[]
  transcriptionJobs TranscriptionJob[]
  dubbingEpisodeTranscription Episode? @relation("EpisodeTranscriptionProject")
}

model SubtitleFile {
  id                String             @id @default(cuid())
  filename          String
  wavFilename       String?
  wavPath           String?
  language          String?
  sourceType        SubtitleSourceType @default(UPLOADED_SRT)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  projectId         String
  project           Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  cues              SubtitleCue[]
  versions          SubtitleVersion[]
  transcriptionJobs TranscriptionJob[]
  mediaAssets       MediaAsset[]
  episodeSubtitleOutput Episode? @relation("EpisodeSubtitleOutput")
  episodeAudio          Episode? @relation("EpisodeAudio")
}

model SubtitleCue {
  id                 String           @id @default(cuid())
  cueIndex           Int
  startMs            Int
  endMs              Int
  text               String
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  subtitleFileId     String
  subtitleFile       SubtitleFile     @relation(fields: [subtitleFileId], references: [id], onDelete: Cascade)
  transcriptionJobId String?
  transcriptionJob   TranscriptionJob? @relation(fields: [transcriptionJobId], references: [id], onDelete: SetNull)

  @@index([subtitleFileId, cueIndex])
  @@index([subtitleFileId, startMs])
}

model BatchJob {
  id            String              @id @default(cuid())
  status        BatchJobStatus      @default(PENDING)
  engine        TranscriptionEngine @default(OPENAI_WHISPER)
  language      String?
  zipStorageKey String?
  totalFiles    Int                 @default(0)
  userId        String
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime            @default(now())
  completedAt   DateTime?
  jobs          TranscriptionJob[]
}

model TranscriptionJob {
  id               String                 @id @default(cuid())
  projectId        String
  project          Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subtitleFileId   String
  subtitleFile     SubtitleFile           @relation(fields: [subtitleFileId], references: [id], onDelete: Cascade)
  batchId          String?
  batch            BatchJob?              @relation(fields: [batchId], references: [id], onDelete: SetNull)
  originalFilename String?
  exportFormat     String?                @default("SRT")
  status           TranscriptionJobStatus @default(PENDING)
  engine           TranscriptionEngine    @default(OPENAI_WHISPER)
  language         String?
  errorMessage     String?
  attemptCount     Int                    @default(0)
  rawResponse      Json?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime               @default(now())
  cues             SubtitleCue[]

  @@index([projectId])
  @@index([subtitleFileId])
  @@index([batchId])
}

model SubtitleVersion {
  id             String       @id @default(cuid())
  versionNumber  Int
  label          String?
  srtContent     String
  createdAt      DateTime     @default(now())
  subtitleFileId String
  subtitleFile   SubtitleFile @relation(fields: [subtitleFileId], references: [id], onDelete: Cascade)

  @@unique([subtitleFileId, versionNumber])
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum SubtitleSourceType {
  UPLOADED_SRT
  IMPORTED_BUZZ
  IMPORTED_WHISPER
}

enum MediaKind {
  audio
  video
}

enum BatchJobStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

enum TranscriptionJobStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

enum TranscriptionEngine {
  OPENAI_WHISPER
  MOCK
}

model Client {
  id        String       @id @default(cuid())
  name      String
  email     String?      @unique
  phone     String?      @unique
  country   String?
  notes     String?
  status    ClientStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  projects          DubbingProject[]
  communicationLogs CommunicationLog[]
}

enum ClientStatus {
  ACTIVE
  INACTIVE
}

model DubbingProject {
  id            String               @id @default(cuid())
  name          String
  client        String?
  clientId      String?
  clientRef     Client?              @relation(fields: [clientId], references: [id], onDelete: SetNull)
  status        DubbingProjectStatus @default(SPOTTING)
  startDate     DateTime?
  deadline      DateTime?
  /// Número planeado de episódios (coluna `episodes` na BD).
  episodeCount  Int?                 @map("episodes")
  durationMin   Int?
  language      String?
  value         Decimal?             @db.Decimal(10, 2)
  valueCurrency ValueCurrency        @default(BRL)
  paymentType   PaymentType          @default(PER_PROJECT)
  notes         String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  userId        String?
  characters    ProjectCharacter[]
  characterAssignments ProjectCharacterAssignment[]
  recordingSessions RecordingSession[]
  episodes          Episode[]
  communicationLogs CommunicationLog[]

  @@index([status])
  @@index([deadline])
}

/// Episódio de projeto de dublagem (linha editoral por número).
model Episode {
  id             String         @id @default(cuid())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  editedAt       DateTime?
  number         Int
  title          String?
  status         EpisodeStatus  @default(PENDING)
  subtitleFileId String?        @unique
  subtitleFile   SubtitleFile?  @relation("EpisodeSubtitleOutput", fields: [subtitleFileId], references: [id], onDelete: SetNull)
  audioFileId    String?        @unique
  audioFile      SubtitleFile?  @relation("EpisodeAudio", fields: [audioFileId], references: [id], onDelete: SetNull)
  transcriptionProjectId String? @unique
  transcriptionProject     Project? @relation("EpisodeTranscriptionProject", fields: [transcriptionProjectId], references: [id], onDelete: SetNull)
  projectId      String
  project        DubbingProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  recordingSessions RecordingSession[]
  recordingSessionEpisodes RecordingSessionEpisode[]
  communicationLogs      CommunicationLog[]

  @@unique([projectId, number])
  @@index([projectId])
}

enum EpisodeStatus {
  PENDING
  TRANSCRIBING
  DONE
}

enum DubbingProjectStatus {
  SPOTTING
  ADAPTATION
  REVIEW
  RECORDING
  DELIVERY
  DONE
  PAUSED
}

enum PaymentType {
  PER_PROJECT
  PER_EPISODE
  PER_MINUTE
}

enum ValueCurrency {
  BRL
  USD
}

enum ProjectCharacterAssignmentType {
  TEST_OPTION_1
  TEST_OPTION_2
  PRINCIPAL
  RESERVE
  SUPPORT
}

enum ProjectCharacterAssignmentStatus {
  INVITED
  TEST_SENT
  TEST_RECEIVED
  APPROVED
  CAST
  REPLACED
  DECLINED
}

model CastMember {
  id          String           @id @default(cuid())
  name        String
  role        String?
  whatsapp    String?          @unique
  email       String?          @unique
  specialties String[]
  status      CastMemberStatus @default(AVAILABLE)
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  characters  ProjectCharacter[]
  characterAssignments ProjectCharacterAssignment[]
  recordingSessions RecordingSession[]
  availabilities    CastMemberAvailability[]
  communicationLogs CommunicationLog[]
}

model CastMemberAvailability {
  id           String                     @id @default(cuid())
  castMemberId String
  castMember   CastMember                 @relation(fields: [castMemberId], references: [id], onDelete: Cascade)
  startAt      DateTime
  endAt        DateTime
  type         CastMemberAvailabilityType
  notes        String?
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt

  @@index([castMemberId])
  @@index([castMemberId, startAt])
}

model ProjectCharacter {
  id           String              @id @default(cuid())
  projectId    String
  project      DubbingProject      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name         String
  type         String?
  voiceType    String?
  importance   CharacterImportance @default(SUPPORT)
  castMemberId String?
  castMember   CastMember?         @relation(fields: [castMemberId], references: [id], onDelete: SetNull)
  assignments  ProjectCharacterAssignment[]
  recordingSessions RecordingSession[]
  notes        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([projectId])
}

model ProjectCharacterAssignment {
  id              String                          @id @default(cuid())
  projectId        String
  project          DubbingProject                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  characterId      String
  character        ProjectCharacter               @relation(fields: [characterId], references: [id], onDelete: Cascade)
  castMemberId     String
  castMember       CastMember                     @relation(fields: [castMemberId], references: [id], onDelete: Restrict)
  type             ProjectCharacterAssignmentType
  status           ProjectCharacterAssignmentStatus @default(INVITED)
  priority         Int                             @default(1)
  approvedByClient Boolean                         @default(false)
  notes            String?
  createdAt        DateTime                        @default(now())
  updatedAt        DateTime                        @updatedAt

  @@index([projectId])
  @@index([characterId])
  @@index([castMemberId])
  @@index([projectId, characterId])
  @@index([projectId, castMemberId])
  @@index([type, status])
}

enum CharacterImportance {
  MAIN
  SUPPORT
  EXTRA
}

enum CastMemberStatus {
  AVAILABLE
  BUSY
  INACTIVE
}

/// Períodos manuais de disponibilidade / indisponibilidade do dublador (camada separada de sessões).
enum CastMemberAvailabilityType {
  AVAILABLE
  UNAVAILABLE
  BLOCKED
}

enum RecordingSessionStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum RecordingSessionFormat {
  REMOTE
  IN_PERSON
}

model RecordingSession {
  id           String                 @id @default(uuid())
  projectId    String
  project      DubbingProject         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  episodeId    String?
  episode      Episode?               @relation(fields: [episodeId], references: [id], onDelete: SetNull)
  characterId  String?
  character    ProjectCharacter?      @relation(fields: [characterId], references: [id], onDelete: SetNull)
  castMemberId String
  castMember   CastMember             @relation(fields: [castMemberId], references: [id], onDelete: Restrict)
  title        String
  startAt      DateTime
  endAt        DateTime
  status       RecordingSessionStatus @default(PENDING)
  format       RecordingSessionFormat
  notes        String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  sessionEpisodes RecordingSessionEpisode[]
  communicationLogs CommunicationLog[]

  @@index([projectId])
  @@index([castMemberId])
  @@index([episodeId])
  @@index([characterId])
  @@index([projectId, startAt])
}

enum CommunicationChannel {
  EMAIL
  WHATSAPP
  SYSTEM
}

enum CommunicationDirection {
  OUTBOUND
  INBOUND
}

enum CommunicationStatus {
  PENDING
  /// Pedido de envio por e-mail em fila / a processar pelo worker (PR 23).
  PROCESSING
  SENT
  RECEIVED
  FAILED
}

/// Histórico manual de comunicação (e-mail, WhatsApp, sistema). Não envia mensagens; não é auditoria de ações.
model CommunicationLog {
  id                 String                  @id @default(cuid())
  channel            CommunicationChannel
  direction          CommunicationDirection
  status             CommunicationStatus
  subject            String?
  body               String
  templateKey        String?
  recipientName      String?
  recipientEmail     String?
  recipientWhatsapp  String?
  dubbingProjectId   String?
  dubbingProject     DubbingProject?         @relation(fields: [dubbingProjectId], references: [id], onDelete: Cascade)
  episodeId          String?
  episode            Episode?                @relation(fields: [episodeId], references: [id], onDelete: SetNull)
  castMemberId       String?
  castMember         CastMember?             @relation(fields: [castMemberId], references: [id], onDelete: SetNull)
  clientId           String?
  client             Client?                 @relation(fields: [clientId], references: [id], onDelete: SetNull)
  sessionId          String?
  session            RecordingSession?       @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  sentAt             DateTime?
  error              String?
  /// ID retornado pelo provider (Resend) quando o envio é aceite.
  providerMessageId  String?
  /// Marca de “claim” pelo worker para evitar envio duplicado.
  sendLockedAt       DateTime?
  sendAttemptCount   Int                   @default(0)
  lastSendAttemptAt  DateTime?
  /// Próxima janela de tentativa (retry simples, sem scheduler complexo).
  nextRetryAt        DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  @@index([dubbingProjectId])
  @@index([dubbingProjectId, createdAt])
  @@index([status, channel])
  @@index([status, channel, nextRetryAt])
}

/// Liga sessão de gravação a um ou mais episódios (N:N).
model RecordingSessionEpisode {
  id        String           @id @default(uuid())
  sessionId String
  session   RecordingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  episodeId String
  episode   Episode          @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())

  @@unique([sessionId, episodeId])
  @@index([sessionId])
  @@index([episodeId])
}

/// Registo canónico de ficheiros em object storage (S3-compatible). PR 4.3 — sem rotas de produto ainda.
model MediaAsset {
  id               String            @id @default(cuid())
  kind             MediaAssetKind
  status           MediaAssetStatus  @default(PENDING)
  visibility       MediaVisibility   @default(PRIVATE)
  /// Ex.: "s3-compatible", "local" — valor livre nesta fase.
  storageProvider  String
  bucket           String
  objectKey        String
  originalFilename String
  mimeType         String?
  sizeBytes        BigInt?
  checksumSha256   String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  /// PR 5.4 — vínculo opcional ao `SubtitleFile` ativo após upload; histórico pode ficar sem FK.
  subtitleFileId   String?
  subtitleFile     SubtitleFile?     @relation(fields: [subtitleFileId], references: [id], onDelete: SetNull)

  @@unique([bucket, objectKey])
  @@index([status])
  @@index([kind])
  @@index([subtitleFileId])
}

enum MediaAssetKind {
  AUDIO
  VIDEO
  OTHER
}

enum MediaAssetStatus {
  PENDING
  READY
  FAILED
  ARCHIVED
}

enum MediaVisibility {
  PRIVATE
  INTERNAL
  PUBLIC
}
