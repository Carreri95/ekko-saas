generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  name      String?
  email     String?   @unique
  password  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  projects  Project[]
  batchJobs BatchJob[]
}

model Project {
  id            String           @id @default(cuid())
  name          String
  description   String?
  status        ProjectStatus    @default(DRAFT)
  /// Referência opaca ao arquivo no storage (ex.: UUID + extensão). Nunca expor path de disco.
  storageKey    String?
  mediaKind     MediaKind?
  durationMs    Int?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  subtitleFiles SubtitleFile[]
  transcriptionJobs TranscriptionJob[]
}

model SubtitleFile {
  id          String             @id @default(cuid())
  filename    String
  wavFilename String?
  wavPath     String?
  language    String?
  sourceType  SubtitleSourceType @default(UPLOADED_SRT)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  projectId   String
  project     Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  cues        SubtitleCue[]
  versions    SubtitleVersion[]
  transcriptionJobs TranscriptionJob[]
}

model SubtitleCue {
  id             String       @id @default(cuid())
  cueIndex       Int
  startMs        Int
  endMs          Int
  text           String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  subtitleFileId String
  subtitleFile   SubtitleFile @relation(fields: [subtitleFileId], references: [id], onDelete: Cascade)
  /// Job que gerou a cue (null = manual ou legado).
  transcriptionJobId String?
  transcriptionJob   TranscriptionJob? @relation(fields: [transcriptionJobId], references: [id], onDelete: SetNull)

  @@index([subtitleFileId, cueIndex])
  @@index([subtitleFileId, startMs])
}

model BatchJob {
  id        String         @id @default(cuid())
  status    BatchJobStatus @default(PENDING)
  engine    TranscriptionEngine @default(OPENAI_WHISPER)
  language  String?
  zipStorageKey String?
  totalFiles Int           @default(0)
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())
  completedAt DateTime?
  jobs      TranscriptionJob[]
}

model TranscriptionJob {
  id             String                 @id @default(cuid())
  projectId      String
  project        Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subtitleFileId String
  subtitleFile   SubtitleFile           @relation(fields: [subtitleFileId], references: [id], onDelete: Cascade)
  batchId        String?
  batch          BatchJob?              @relation(fields: [batchId], references: [id], onDelete: SetNull)
  /// Nome original do ficheiro upload (gerador em lote).
  originalFilename String?
  /// Ex.: SRT, TXT, VTT — UI do gerador.
  exportFormat   String?                @default("SRT")
  status         TranscriptionJobStatus   @default(PENDING)
  engine         TranscriptionEngine      @default(OPENAI_WHISPER)
  language       String?
  errorMessage   String?
  attemptCount   Int                    @default(0)
  rawResponse    Json?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime               @default(now())
  cues           SubtitleCue[]

  @@index([projectId])
  @@index([subtitleFileId])
  @@index([batchId])
}

model SubtitleVersion {
  id             String       @id @default(cuid())
  versionNumber  Int
  label          String?
  srtContent     String
  createdAt      DateTime     @default(now())
  subtitleFileId String
  subtitleFile   SubtitleFile @relation(fields: [subtitleFileId], references: [id], onDelete: Cascade)

  @@unique([subtitleFileId, versionNumber])
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum SubtitleSourceType {
  UPLOADED_SRT
  IMPORTED_BUZZ
  IMPORTED_WHISPER
}

enum MediaKind {
  audio
  video
}

enum BatchJobStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

enum TranscriptionJobStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

enum TranscriptionEngine {
  OPENAI_WHISPER
  MOCK
}

/// Projetos de dublagem / gestão (separado de `Project` de transcrição).
model DubbingProject {
  id          String                 @id @default(cuid())
  name        String
  client      String?
  status      DubbingProjectStatus   @default(SPOTTING)
  startDate   DateTime?
  deadline    DateTime?
  episodes    Int?
  durationMin Int?
  language    String?
  value         Decimal?      @db.Decimal(10, 2)
  valueCurrency ValueCurrency @default(BRL)
  paymentType   PaymentType   @default(PER_PROJECT)
  notes       String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  userId      String?

  @@index([status])
  @@index([deadline])
}

enum DubbingProjectStatus {
  SPOTTING
  ADAPTATION
  REVIEW
  RECORDING
  DELIVERY
  DONE
  PAUSED
}

enum PaymentType {
  PER_PROJECT
  PER_EPISODE
  PER_MINUTE
}

enum ValueCurrency {
  BRL
  USD
}
