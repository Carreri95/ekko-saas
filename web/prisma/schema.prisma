generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  name      String?
  email     String?   @unique
  password  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  projects  Project[]
}

model Project {
  id            String           @id @default(cuid())
  name          String
  description   String?
  status        ProjectStatus    @default(DRAFT)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  subtitleFiles SubtitleFile[]
}

model SubtitleFile {
  id          String             @id @default(cuid())
  filename    String
  wavFilename String?
  wavPath     String?
  language    String?
  sourceType  SubtitleSourceType @default(UPLOADED_SRT)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  projectId   String
  project     Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  cues        SubtitleCue[]
  versions    SubtitleVersion[]
}

model SubtitleCue {
  id             String       @id @default(cuid())
  cueIndex       Int
  startMs        Int
  endMs          Int
  text           String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  subtitleFileId String
  subtitleFile   SubtitleFile @relation(fields: [subtitleFileId], references: [id], onDelete: Cascade)

  @@index([subtitleFileId, cueIndex])
}

model SubtitleVersion {
  id             String       @id @default(cuid())
  versionNumber  Int
  label          String?
  srtContent     String
  createdAt      DateTime     @default(now())
  subtitleFileId String
  subtitleFile   SubtitleFile @relation(fields: [subtitleFileId], references: [id], onDelete: Cascade)

  @@unique([subtitleFileId, versionNumber])
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum SubtitleSourceType {
  UPLOADED_SRT
  IMPORTED_BUZZ
  IMPORTED_WHISPER
}